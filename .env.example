# PostgreSQL
POSTGRES_DB=retail_orders
POSTGRES_USER=retail
POSTGRES_PASSWORD=retail_secret
POSTGRES_PORT=5432

# MinIO (S3-compatible storage for original uploaded files)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=orders

# Arize Phoenix (AI observability)
PHOENIX_UI_PORT=6006
PHOENIX_GRPC_PORT=4317
PHOENIX_HTTP_PORT=4318

# n8n (workflow orchestration)
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=admin

# API
API_PORT=8000
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Web
WEB_PORT=5173

# Anthropic Claude (required for Parser Agent and Analyst Agent)
ANTHROPIC_API_KEY=your-api-key-here

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# General
TIMEZONE=Europe/Madrid
